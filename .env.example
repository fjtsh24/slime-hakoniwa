# Firebase (Frontend)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=slime-sim-prototype.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=slime-sim-prototype
VITE_FIREBASE_STORAGE_BUCKET=slime-sim-prototype.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin (Functions / Netlify Functions - set in environment, never commit)
FIREBASE_PROJECT_ID=slime-sim-prototype
GCLOUD_PROJECT=slime-sim-prototype

# Firebase Emulator 接続先（ローカル開発時のみ設定。本番 Netlify には設定しないこと）
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
