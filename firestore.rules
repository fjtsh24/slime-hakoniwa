rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // worlds / turnLogs: 認証済み読み取り可、書き込み禁止
    // =========================================================
    match /worlds/{worldId} {
      allow read: if request.auth != null;
      allow write: if false;

      // maps サブコレクション
      match /maps/{mapId} {
        allow read: if request.auth != null;
        allow write: if false;

        // tiles サブコレクション
        match /tiles/{tileId} {
          allow read: if request.auth != null;
          allow write: if false;
        }
      }
    }

    // =========================================================
    // turnLogs: 認証済み読み取り可、書き込み禁止（Admin SDKのみ）
    // =========================================================
    match /turnLogs/{logId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // =========================================================
    // users: 本人のみ読み書き可、削除禁止
    // =========================================================
    match /users/{uid} {
      allow read:   if request.auth != null && request.auth.uid == uid;
      allow create: if false;  // Auth Trigger (Admin SDK) のみ作成可
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['displayName', 'updatedAt']);
      allow delete: if false;
    }

    // =========================================================
    // maps（トップレベル）: 認証済み全員読み取り可、書き込み禁止
    // Phase 6のマップ閲覧機能に対応。書き込みはAuth Trigger（Admin SDK）のみ。
    // =========================================================
    match /maps/{mapId} {
      allow read: if request.auth != null;
      allow write: if false;

      // tiles サブコレクション: マップオーナーのみ読み取り可
      match /tiles/{tileId} {
        allow read: if request.auth != null
                    && get(/databases/$(database)/documents/maps/$(mapId)).data.ownerUid == request.auth.uid;
        allow write: if false;
      }
    }

    // =========================================================
    // slimes: 認証済みユーザーは全件読み取り可、書き込み禁止
    // =========================================================
    match /slimes/{slimeId} {
      allow read:  if request.auth != null;
      allow write: if false;

      // skills サブコレクション
      match /skills/{skillId} {
        allow read:  if request.auth != null;
        allow write: if false;
      }
    }

    // =========================================================
    // actionReservations: 本人のみ読み取り・作成可、更新・削除禁止
    // =========================================================
    match /actionReservations/{reservationId} {
      // 読み取り：自分の予約のみ
      allow read: if request.auth != null
                  && resource.data.ownerUid == request.auth.uid;

      // 作成：ownerUid が自身、status が 'pending'、必須フィールドが存在する
      // また、slimeId が示すスライムの ownerUid が自身であることを get() で確認する。
      // トレードオフ: get() によるドキュメント参照はルール評価ごとに Firestore 読み取りが
      // 発生するため評価コストが増加する。APIを経由する正規フローでは Admin SDK が
      // 事前チェックを行うため、このルールは主にAPIバイパス攻撃への防御層として機能する。
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.keys().hasAll([
                         'slimeId',
                         'worldId',
                         'turnNumber',
                         'actionType',
                         'actionData'
                       ])
                    // slimeの所有者確認（get()でFirestore読み取り）
                    && get(/databases/$(database)/documents/slimes/$(request.resource.data.slimeId)).data.ownerUid == request.auth.uid;

      // 更新・削除は禁止（Admin SDKがキャンセル処理を行う）
      allow update: if false;
      allow delete: if false;
    }

    // =========================================================
    // マスタデータ: 認証済み読み取り可、書き込み禁止
    // =========================================================
    match /skillDefinitions/{skillId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    match /foods/{foodId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    match /slimeSpecies/{speciesId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
  }
}
