{
  "name": "slime-hakoniwa",
  "private": true,
  "scripts": {
    "dev:functions": "netlify dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "emulator": "firebase emulators:start --import=./emulator-data --export-on-exit=./emulator-data",
    "emulator:fresh": "firebase emulators:start --export-on-exit=./emulator-data",
    "emulator:reset": "node scripts/reset-emulator.mjs",
    "seed": "cd functions && FIRESTORE_EMULATOR_HOST=localhost:8080 FIREBASE_AUTH_EMULATOR_HOST=localhost:9099 npx ts-node --project tsconfig.json src/scripts/seed.ts"
  }
}
